APP_BASE_URL=https://your-domain.example
TELEGRAM_BOT_TOKEN=telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=replace_with_1_to_256_char_telegram_webhook_secret
TELEGRAM_UPDATE_DEDUPE_TTL_SECONDS=86400
TELEGRAM_ACTION_THROTTLE_SECONDS=3
CRON_SECRET=replace_with_1_to_256_char_vercel_cron_secret
NOTIFICATION_RETRY_SECRET=replace_with_1_to_256_char_manual_retry_secret
NOTIFICATION_OPS_SECRET=replace_with_1_to_256_char_ops_secret
NOTIFICATION_RECEIPT_DIAGNOSTICS_LIMIT=20
ADMIN_CHAT_ID=123456789
TG_OPERATOR_IDS=123456789,987654321
OPERATOR_TELEGRAM_USER_IDS=123456789
NOTIFICATION_RETRY_DELAY_SECONDS=300
NOTIFICATION_RETRY_BATCH_SIZE=10
NOTIFICATION_RETRY_CLAIM_TIMEOUT_SECONDS=60
NOTIFICATION_MAX_ATTEMPTS=3
LINKEDIN_CLIENT_ID=linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=https://your-domain.example/api/oauth/callback/linkedin
LINKEDIN_SCOPES=openid profile
# Add email later only if you intentionally want LinkedIn email claims: openid profile email
LINKEDIN_STATE_SECRET=replace_with_32_plus_char_secret
LINKEDIN_STATE_TTL_SECONDS=600
LINKEDIN_OIDC_DISCOVERY_URL=https://www.linkedin.com/oauth/.well-known/openid-configuration
LINKEDIN_JWKS_CACHE_TTL_SECONDS=3600
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_SSLMODE=require
NODE_ENV=development
