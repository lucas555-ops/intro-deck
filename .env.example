TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=rollduelbot
CRYPTO_PAY_API_TOKEN=replace_me
ADMIN_IDS=123456789

# Database
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/roll_duel
DATABASE_FILE=dice_game.db

# Delivery/runtime
TELEGRAM_DELIVERY_MODE=webhook
APP_BASE_URL=https://your-domain.example
APP_HOST=0.0.0.0
PORT=8080
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
CRYPTOPAY_WEBHOOK_PATH=/webhook/cryptopay
TELEGRAM_WEBHOOK_SECRET=replace_me_strong_secret
ENABLE_INVOICE_POLLING=0
# Legacy fallback only. Keep disabled in the normal webhook baseline.

# Classic bot surface
SUPPORT_TELEGRAM_HANDLE=@rollduelbot
SUPPORT_TON_ADDRESS=
# Legacy DurovCube handles are ignored at runtime and fall back to @rollduelbot.

# Runtime tuning
WAITING_DUEL_TIMEOUT_SECONDS=900
ACTIVE_DUEL_TIMEOUT_SECONDS=300
RECONCILIATION_INTERVAL_SECONDS=20
ADMIN_BROADCAST_TICK_SECONDS=15
ADMIN_BROADCAST_BATCH_SIZE=25
ADMIN_BROADCAST_MAX_RETRIES=3
LOG_LEVEL=INFO

# Operator web UI
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=replace_me
ADMIN_WEB_PREFIX=/admin

# Product switches
# Optional at boot; defaults are seeded into platform_settings

# Mini App (frozen / dormant by default)
MINIAPP_RUNTIME_ENABLED=0
MINIAPP_PREFIX=/app
MINIAPP_API_PREFIX=/api/miniapp
MINIAPP_INIT_MAX_AGE_SECONDS=86400
MINIAPP_SESSION_TTL_SECONDS=86400
MINIAPP_SMOKE_CAPTURE_ENABLED=1
